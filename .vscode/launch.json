{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Quote",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--disable-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: build"
    },
    {
      "name": "Run Quote Tests",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--disable-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/dist-test/tests/integration"
      ],
      "outFiles": ["${workspaceFolder}/dist-test/**/*.js"],
      "preLaunchTask": "npm: compile-tests"
    }
  ]
}
