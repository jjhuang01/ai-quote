{
  "name": "ai-quote",
  "displayName": "Quote",
  "icon": "resources/icon.png",
  "description": "",
  "version": "2.9.1",
  "publisher": "opensource",
  "license": "MIT",
  "author": "EVILZIXIE",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "tool",
    "helper",
    "utility"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "quote-sidebar",
          "title": "Quote",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "quote-sidebar": [
        {
          "type": "webview",
          "id": "quoteView",
          "name": "Quote",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "quote.openPanel",
        "title": "Quote: Open Panel",
        "icon": "$(window)"
      },
      {
        "command": "quote.refresh",
        "title": "Quote: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "quote.testFeedback",
        "title": "Quote: Test Feedback"
      },
      {
        "command": "quote.showStatus",
        "title": "Quote: Show Status"
      },
      {
        "command": "quote.copyPort",
        "title": "Quote: Copy Port"
      },
      {
        "command": "quote.rotateName",
        "title": "Quote: Rotate MCP Name"
      },
      {
        "command": "quote.testDialog",
        "title": "Quote: Test Dialog (Simulate LLM Call)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "quote.refresh",
          "when": "view == quoteView",
          "group": "navigation"
        },
        {
          "command": "quote.openPanel",
          "when": "view == quoteView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Quote",
      "properties": {
        "quote.serverPort": {
          "type": "number",
          "default": 3456,
          "description": "服务端口"
        },
        "quote.autoConfigureRules": {
          "type": "boolean",
          "default": false,
          "description": "自动配置全局规则"
        },
        "quote.dialogTimeoutSeconds": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "MCP 对话框超时秒数（0 = 不超时，无限等待用户回复）"
        }
      }
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit -p tsconfig.json",
    "build": "npm run check-types && node esbuild.mjs",
    "compile-tests": "tsc -p tsconfig.tests.json",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test": "npm run test:unit && npm run test:e2e",
    "dev": "node esbuild.mjs --watch",
    "dev:debug": "npm run build && /Applications/vscode.app/Contents/Resources/app/bin/code --extensionDevelopmentPath=\"$PWD\" --disable-extensions",
    "test:integration": "npm run build && npm run compile-tests && vscode-test",
    "verify": "npm run check-types && npm run build && npm run test && npm run test:integration",
    "vscode:prepublish": "npm run build",
    "release": "npm version patch --no-git-tag-version && vsce package --no-dependencies",
    "release:minor": "npm version minor --no-git-tag-version && vsce package --no-dependencies",
    "release:major": "npm version major --no-git-tag-version && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.0",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.5",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.44",
    "mammoth": "^1.11.0",
    "mermaid": "^11.14.0",
    "proxy-agent": "^6.3.0",
    "xlsx": "^0.18.5"
  }
}
